# 複製為 .env（勿提交 .env）
TEJ_API_KEY=
FINMIND_TOKEN=
PERPLEXITY_API_KEY=

# === 方案 C：① 執行評估（週一至五 08:30 · 0830執行評估.command）===
ENABLE_FINMIND_SIGNAL=0

# === 方案 C：② 收盤持股雷達（週一至五 16:30 · 1630收盤雷達.command）===
RUN_STOCK_MARKET_SYNC=0
STOCK_MARKET_LOOKBACK_DAYS=60
STOCK_MARKET_FORCE_REFRESH=0

RUN_SCORE_ENGINE=1
RUN_EXPORT_AI_BUNDLE=1
RUN_MEMO=0

# 催化：預設人工上網查（收盤寫 reports/*_evening_brief.md）；勿用 manual_events
USE_MANUAL_EVENTS=0
RUN_CATALYST_ENGINE=0
RUN_NEWS_SYNC=0
RUN_PERPLEXITY_SUMMARY=0
RUN_PERPLEXITY_VERIFY=0
PERPLEXITY_MODEL=sonar
NEWS_LOOKBACK_DAYS=7
PERPLEXITY_VERIFY_MAX=8

# 價位門檻（乖離過大 · 不計入綜合評分）
ENTRY_OVEREXTENDED_ABS_MIN=13
ENTRY_OVEREXTENDED_REL_PCT=78

PORTFOLIO_CAPITAL_NTD=100000

# === E0 開盤訂單草稿（① 早盤；見 docs/PRD.md §21）===
RUN_ORDER_INTENT=1
# IPS 範本：config/investment_policy.example.yaml → 複製為 data/investment_policy.yaml
# 執行評估報價（0845試撮等）：manual | yahoo | finmind | auto
EXECUTION_EVAL_PRICE_SOURCE=manual
# 0905盤中預覽.command 預設 Yahoo 自動查（不受上行影響）；可覆寫：
# INTRADAY_PREVIEW_PRICE_SOURCE=yahoo
# INTRADAY_PREVIEW_PRICES=2330=2380,6223=5760
# auto 時 FinMind register 無 tick 會改拉 Yahoo（延遲可能 15 分）；0=關閉
EXECUTION_EVAL_YAHOO_FALLBACK=1

# 可選：重大事件日才開 Perplexity 查證（會重算 Score）
# RUN_PERPLEXITY_VERIFY=1
