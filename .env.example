# 複製為 .env（勿提交 .env）
TEJ_API_KEY=
FINMIND_TOKEN=

# 富邦 Neo API · Order layer（scripts/order/fubon_login_test.py · .venv-fubon）
# 建立：python3.13 -m venv .venv-fubon && .venv-fubon/bin/pip install CAFubon/fubon_neo-*.whl
# 執行：.venv-fubon/bin/python scripts/order/fubon_login_test.py [--snapshot]
# 策略意圖送單：.venv-fubon/bin/python scripts/order/submit_intents.py reports/order/intents/<file>.json --dry-run
# 開盤排程（已停用 · 原週一至五 09:00–09:04）：scripts/install-order-launchd.sh
# ORDER_LAUNCHD_ENABLED=0   # 設為 1 並 install-order-launchd.sh 才啟用 launchd 送單
FUBON_USER_ID=
FUBON_PASSWORD=
FUBON_CERT_PATH=
FUBON_CERT_PASSWORD=
# FUBON_API_KEY=   # 選填；>= SDK v2.2.7，申請：https://www.fbs.com.tw/TradeAPI/docs/key.txt

# etfedge MCP backfill（scripts/import_etfedge_holdings.py）
# 登入：.venv/bin/python scripts/etfedge_oauth_login.py
ETFEDGE_MCP_TOKEN=

# === 排程通知郵件（Gmail → Mail.app 收件匣；各排程可個別關閉）===
# 方式 A（推薦）：Gmail App 密碼 → https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
# 或 GMAIL_APP=（與 GMAIL_APP_PASSWORD 擇一；含空格請加引號）
GMAIL_NOTIFY_FROM=your@gmail.com
GMAIL_NOTIFY_TO=your@gmail.com
# 方式 B（選填）：Google Apps Script Web App URL（見下方說明，不需在本機存密碼）
# NOTIFY_WEBHOOK_URL=
# NOTIFY_WEBHOOK_SECRET=
RUN_EVENING_HOLDINGS_EMAIL=1
RUN_WEEKLY_DEEP_EMAIL=1
RUN_RRG_MONO_INTRADAY_EMAIL=1
RUN_VCP_FUNNEL_SPECS_EMAIL=1
RUN_ETFEDGE_IMPORT_EMAIL=1
RUN_RRG_MONO_EMAIL=1
# 安聯台灣科技基金（ACDD04）月報公布偵測；僅新快照寄信
RUN_MUTUAL_FUND_DISCLOSURE_EMAIL=1

# === Supabase · 網站層（Readdy 讀取 · 本機 upsert）===
# 專案 ref: lzaomqzsiqudkojokevr · 三 schema 並存（勿混用）：
#   stock_research — 股市研究（daily_briefs · site_content · strategy_performance_yearly …）
#   photobooking   — 官網預約（booking_logs；非 public）
#   public         — yahoo_quotes · yahoo_daily_bars 快取（無研究表 · 無預約表）
# Readdy 前端：VITE_PUBLIC_SUPABASE_URL + VITE_PUBLIC_SUPABASE_ANON_KEY
#   createClient(..., { db: { schema: 'stock_research' } })
# 本機 upsert：SUPABASE_SERVICE_ROLE_KEY · 手動 backfill 或排程 sync
SUPABASE_URL=https://lzaomqzsiqudkojokevr.supabase.co
SUPABASE_PROJECT_REF=lzaomqzsiqudkojokevr
SUPABASE_SERVICE_ROLE_KEY=
RUN_SUPABASE_RESEARCH_SYNC=0
# 收盤 16:30 lens → Supabase（evening-holdings 預設 1；與 brief sync 分離）
RUN_STOCK_DAILY_LENS=1
RUN_SUPABASE_LENS_SYNC=1
RUN_LENS_DAILY_NOTIFY=0
# 已採納策略分年績效 → Supabase strategy_performance_yearly
RUN_STRATEGY_PERF_SYNC=1
# Regime embed HTML（預設關；Readdy 用 snapshot_json）
RUN_REGIME_EMBED_HTML=0
# 本機 research standalone HTML（RRG timeline 等；非網站 VFP）
RUN_RESEARCH_HTML_GEN=0
# stock_signal_hits 索引（隨 brief sync；預設 1）
RUN_SUPABASE_SIGNAL_SYNC=1

# === ② 收盤持股雷達（週一至五 16:30 · scripts/daily_sync.sh）===
RUN_STOCK_MARKET_SYNC=1
# RRG universe close + mono 槽位（需 RUN_STOCK_MARKET_SYNC=1）
RUN_RRG_UNIVERSE_CLOSE=1
RUN_RRG_MONO_DAILY=1
RUN_RRG_MONO_SWAP_ACCEL_DAILY=1
STOCK_MARKET_LOOKBACK_DAYS=60
STOCK_MARKET_FORCE_REFRESH=0
RUN_CHIP_SYNC=1
CHIP_LOOKBACK_DAYS=14
RUN_SPONSOR_CHIP_SYNC=1
SPONSOR_CHIP_TOP_N=20

# === VCP Pivot Gate / Coil Close（週一至五 13:00 · scripts/launchd/vcp-funnel-specs.command）===
RUN_VCP_FUNNEL_SPECS=1
# 收盤後 VCP funnel 正式 screen + brief（daily_sync 16:30；需 RUN_STOCK_MARKET_SYNC=1）
RUN_VCP_FUNNEL_CLOSE=1

# === RRG mono（週一至五 13:00 預警 · 16:30 daily_sync 收盤確認）===
RUN_RRG_MONO_INTRADAY_WATCH=1
# 13:00 全 universe RRG 寫 SQLite + Supabase（併入 intraday-watch job）
RUN_RRG_UNIVERSE_SNAPSHOT=1
# RRG_MONO_ETF_CODES=00981A,00403A,009816,00980A,00982A,00992A

# === C18acc · rrg-mono-swap-accel live screen（严格对齐回测 · backtest_pit）===
# 5m poll：scripts/install-launchd.sh → com.jackm4.etf.rrg-c18acc-poll
RUN_RRG_C18ACC_SCREEN=1
ORDER_C18ACC_DRY_RUN=1
ORDER_C18ACC_APPLY_STATE=1
RUN_RRG_C18ACC_EMAIL=1
C18ACC_KBAR_SYNC=1
C18ACC_BUDGET_TWD_PER_SLOT=20000
# 0=零股（預設 floor 預算／價）· 1=整張（1000 股倍數）
C18ACC_BOARD_LOT=0
# 手動候選（僅當日；刪除即回 PIT fresh mono）
# C18ACC_POOL_OVERRIDE=3711,6488,2344,3008
# C18ACC_POOL_OVERRIDE_DATE=2026-06-24
# intent 預覽：.venv-fubon/bin/python scripts/order/submit_intents.py reports/order/intents/rrg-mono-swap-accel_<date>.json --dry-run

# === 週日深度補庫（scripts/weekly_sync.sh）===
# alphalens-style 因子驗證（較重，預設關）
RUN_FACTOR_VALIDATION=0

# === 研究參數（非 daily close）===
ENTRY_OVEREXTENDED_ABS_MIN=13
ENTRY_OVEREXTENDED_REL_PCT=78
PORTFOLIO_CAPITAL_NTD=100000

# IPS：config/investment_policy.example.yaml → data/investment_policy.yaml

# === 已退役（勿再設 1）===
